<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnConnect"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Connect Glasses"
            android:enabled="false" />

        <Button
            android:id="@+id/btnTranscribe"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="Start Inspection"
            android:enabled="false" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp">

        <ImageButton
            android:id="@+id/btnLoadFloorPlan"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:src="@drawable/ic_tabler_map"
            android:scaleType="centerInside"
            android:contentDescription="Load floor plan" />

        <ImageButton
            android:id="@+id/btnLoadDocs"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:src="@drawable/ic_tabler_files"
            android:scaleType="centerInside"
            android:contentDescription="Load documents" />

        <ImageButton
            android:id="@+id/btnSummary"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:src="@drawable/ic_tabler_list_details"
            android:scaleType="centerInside"
            android:contentDescription="Speak summary" />

        <ImageButton
            android:id="@+id/btnCapture"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:src="@drawable/ic_tabler_camera"
            android:scaleType="centerInside"
            android:contentDescription="Capture photo" />

        <ImageButton
            android:id="@+id/btnExportPdf"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_tabler_file_pdf"
            android:scaleType="centerInside"
            android:contentDescription="Export PDF" />
    </LinearLayout>

    <CheckBox
        android:id="@+id/cbLocalInference"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Force local inference (Gemma 4 E2B)"
        android:textSize="12sp"
        android:checked="false"
        android:layout_marginTop="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="10dp"
        android:background="#22000000"
        android:padding="6dp">

        <TextView
            android:id="@+id/tvSectionNotes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Observations"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginEnd="10dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Initializing…"
            android:textSize="12sp"
            android:maxLines="2"
            android:ellipsize="end" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/notesScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#11000000"
        android:padding="8dp"
        android:fillViewport="true"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/tvNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Observations will appear here as you speak…"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:textIsSelectable="true" />
    </ScrollView>

    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/floorPlanCompose"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.5"
        android:layout_marginTop="8dp" />

</LinearLayout>
